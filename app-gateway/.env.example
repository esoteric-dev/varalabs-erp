# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/synapse_erp

# Secret used to sign/verify JWTs (change in production!)
JWT_SECRET=dev-secret

# Logging filter (see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=app_gateway=debug,tower_http=debug

# Server bind address (default: 0.0.0.0:3000)
# BIND_ADDR=0.0.0.0:3000
