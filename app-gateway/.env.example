# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/synapse_erp

# Secret used to sign/verify JWTs (change in production!)
JWT_SECRET=dev-secret

# Logging filter (see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=app_gateway=debug,tower_http=debug

# Server bind address (default: 0.0.0.0:3000)
# BIND_ADDR=0.0.0.0:3000

# ─── S3-Compatible Object Storage (MinIO, R2, Backblaze, Wasabi, AWS S3) ──
# Endpoint URL (omit for AWS S3, set for self-hosted/other providers)
S3_ENDPOINT=http://minio:9000
# Access key / secret key (MinIO default for local dev — change in production!)
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
# Bucket name and optional region
S3_BUCKET=erp-uploads
# S3_REGION=us-east-1

# Optional: public URL for serving files via CDN (omit to use nginx proxy path)
# S3_PUBLIC_URL=https://cdn.varalabs.dev
