{
  "framework": "vite",
  "buildCommand": "vite build",
  "devCommand": "vite",
  "installCommand": "bun install",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "git": {
    "deployment": {
      "enabled": true
    }
  }
}
